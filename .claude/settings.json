{
  "permissions": {
    "allow": [
      "Bash(mix precommit:*)",
      "Bash(mix format:*)",
      "Bash(mix compile:*)",
      "Bash(jj diff:*)",
      "Bash(jj diff --git)",
      "Bash(jj status:*)",
      "Bash(emacsclient -e:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(command -v:*)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/bin/agents/agent-notify Claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/bin/agents/block-git-use-jj.sh"
          }
        ]
      }
    ]
  }
}
