prefix_rule(pattern=["mix", "precommit"], decision="allow")
prefix_rule(pattern=["mix", "format"], decision="allow")
prefix_rule(pattern=["mix", "compile"], decision="allow")
prefix_rule(pattern=["jj", "diff"], decision="allow")
prefix_rule(pattern=["jj", "status"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["rg", "--files"], decision="allow")

prefix_rule(pattern=["webget"], decision="allow")
prefix_rule(pattern=["websearch"], decision="allow")
