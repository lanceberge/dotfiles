#!/bin/bash

if [[ -z $1 ]]; then
  exit 0
fi

emacsclient --eval "(+theme-rotate-load-omarchy-theme \"$1\")" >/dev/null 2>&1 || true

colors_file="$HOME/.config/omarchy/current/theme/colors.toml"

color_value() {
  local key=$1
  awk -F'"' -v key="$key" '$1 ~ "^" key "[[:space:]]*=" { print $2; exit }' "$colors_file"
}

if [[ -f $colors_file ]] && command -v tmux >/dev/null 2>&1 && tmux list-clients >/dev/null 2>&1; then
  foreground=$(color_value foreground)
  background=$(color_value background)

  if [[ $foreground == \#?????? && $background == \#?????? ]]; then
    tmux set-option -g window-style "fg=$foreground,bg=$background" >/dev/null 2>&1 || true
    tmux set-option -g window-active-style "fg=$foreground,bg=$background" >/dev/null 2>&1 || true
  fi
fi

if [[ -n $BASH_VERSION && -f "$HOME/dotfiles/bash_config/bash_prompt.sh" ]]; then
  source "$HOME/dotfiles/bash_config/bash_prompt.sh"
elif [[ -n $ZSH_VERSION && -f "$HOME/dotfiles/zsh_config/zsh_prompt.sh" ]]; then
  source "$HOME/dotfiles/zsh_config/zsh_prompt.sh"
fi

prompt_shells_file="${XDG_RUNTIME_DIR:-/tmp}/omarchy/prompt-shells"

# update active shells to reload the prompts w/ new colors
if [[ -f $prompt_shells_file ]]; then
  prompt_shells_active="${prompt_shells_file}.active"
  : >"$prompt_shells_active"

  while IFS=$'\t' read -r prompt_pid prompt_shell; do
    if [[ $prompt_pid =~ ^[0-9]+$ ]] && [[ $prompt_shell == bash || $prompt_shell == zsh ]] && kill -0 "$prompt_pid" 2>/dev/null; then
      printf '%s\t%s\n' "$prompt_pid" "$prompt_shell" >>"$prompt_shells_active"
      kill -USR1 "$prompt_pid" 2>/dev/null || true
    fi
  done <"$prompt_shells_file"

  sort -u "$prompt_shells_active" >"$prompt_shells_file"
  rm -f "$prompt_shells_active"
fi

# Codex caches terminal default colors and refreshes them on focus-gained events.
# Inject that event into tmux panes running Codex so active sessions update live.
if command -v tmux >/dev/null 2>&1 && tmux list-panes -a >/dev/null 2>&1; then
  while IFS=$'\t' read -r pane_id pane_tty; do
    tty_name=${pane_tty#/dev/}

    if [[ -n $pane_id && -n $tty_name ]] && ps -t "$tty_name" -o args= 2>/dev/null | grep -Eq 'codex-linux-.*/bin/codex|node_modules/@openai/codex'; then
      tmux send-keys -t "$pane_id" Escape "[I" >/dev/null 2>&1 || true
    fi
  done < <(tmux list-panes -a -F '#{pane_id}	#{pane_tty}' 2>/dev/null || true)
fi
