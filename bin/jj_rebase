#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: jj_rebase [-d destination] [jj rebase flags]" >&2
}

script_dir() {
    cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

default_destination() {
    local git_trunk
    git_trunk=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)

    git_trunk=$(echo $git_trunk | sed 's#origin/##')
    local bookmarks
    bookmarks=$(jj bookmark list -T 'name ++ "\n"')

    if grep -qx "main" <<<"$bookmarks"; then
        echo "main"
    elif grep -qx "master" <<<"$bookmarks"; then
        echo "master"
    else
        echo "jj_rebase: could not determine default destination; pass -d" >&2
        exit 1
    fi
}

DESTINATION=""
REBASE_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
    -d | --destination)
        if [[ $# -lt 2 ]]; then
            usage
            exit 1
        fi
        DESTINATION="$2"
        shift 2
        ;;
    --destination=*)
        DESTINATION="${1#--destination=}"
        shift
        ;;
    --)
        shift
        REBASE_ARGS+=("$@")
        break
        ;;
    *)
        REBASE_ARGS+=("$1")
        shift
        ;;
    esac
done

if [[ -z "$DESTINATION" ]]; then
    TRUNK_DESTINATION=$(default_destination)
    BOOKMARK=$("$(script_dir)/jj_latest_bookmark")
    CURRENT_REMOTE_DESTINATION="$BOOKMARK@origin"

    printf "rebase %s on:\n" "$BOOKMARK"
    printf "1. %s (default)\n" "$TRUNK_DESTINATION"
    printf "2. %s\n" "$CURRENT_REMOTE_DESTINATION"
    printf "> "
    read -r DESTINATION_CHOICE

    case "$DESTINATION_CHOICE" in
    "" | 1)
        DESTINATION="$TRUNK_DESTINATION"
        ;;
    2)
        DESTINATION="$CURRENT_REMOTE_DESTINATION"
        ;;
    *)
        echo "jj_rebase: invalid destination choice: $DESTINATION_CHOICE" >&2
        exit 1
        ;;
    esac
else
    BOOKMARK=$("$(script_dir)/jj_latest_bookmark")
fi

CMD=(jj rebase -b "$BOOKMARK" -d "$DESTINATION" "${REBASE_ARGS[@]}")

exec "${CMD[@]}"
