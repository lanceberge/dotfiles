#!/usr/bin/env bash
# Creates/selects a worktree and opens it in a tmux window with a 3-pane layout
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    tmux display-message "worktree_workspace: not in a git repo"
    exit 1
}

CURRENT_BRANCH=$(git branch --show-current)

REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_BASE="$HOME/worktrees/$REPO_NAME"
mkdir -p "$WORKTREE_BASE"

EXISTING_WORKTREES=($(
    find "$WORKTREE_BASE" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null || true
))

REMOTE_BRANCHES=($(
    git branch -r 2>/dev/null |
        sed 's/^[[:space:]]*//' |
        grep -v -- '->' |
        sed 's|^origin/||' |
        grep -v "^$CURRENT_BRANCH$" || true
))

# Build fzf list: existing worktrees first, then new branch, then remote branches
FZF_LIST=""
for wt in "${EXISTING_WORKTREES[@]+"${EXISTING_WORKTREES[@]}"}"; do
    FZF_LIST+="[open] $wt"$'\n'
done
FZF_LIST+="new branch"$'\n'
for rb in "${REMOTE_BRANCHES[@]+"${REMOTE_BRANCHES[@]}"}"; do
    # Skip remote branches that already have a worktree
    TR_RB="$(echo "$rb" | tr '/' '_')"
    found=false
    for wt in "${EXISTING_WORKTREES[@]+"${EXISTING_WORKTREES[@]}"}"; do
        if [[ "$wt" == "$TR_RB" ]]; then
            found=true
            break
        fi
    done
    $found || FZF_LIST+="$rb"$'\n'
done
SELECTED=$(printf "%s" "$FZF_LIST" | fzf) || true
[[ -z "${SELECTED:-}" ]] && exit 0

if [[ "$SELECTED" == "[open]"* ]]; then
    TR_BRANCH_NAME="${SELECTED#\[open\] }"
    WORKTREE_PATH="$WORKTREE_BASE/$TR_BRANCH_NAME"
    WINDOW_NAME="worktree/$TR_BRANCH_NAME"
elif [[ "$SELECTED" == "new branch" ]]; then
    read -rp "New branch name: " BRANCH_NAME
    [[ -z "$BRANCH_NAME" ]] && exit 1

    TR_BRANCH_NAME="$(echo "$BRANCH_NAME" | tr '/' '_')"
    WORKTREE_PATH="$WORKTREE_BASE/$TR_BRANCH_NAME"
    WINDOW_NAME="worktree/$TR_BRANCH_NAME"

    if [ ! -d "$WORKTREE_PATH" ]; then
        git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH"
    fi
else
    BRANCH_NAME="$SELECTED"

    TR_BRANCH_NAME="$(echo "$BRANCH_NAME" | tr '/' '_')"
    WORKTREE_PATH="$WORKTREE_BASE/$TR_BRANCH_NAME"
    WINDOW_NAME="worktree/$TR_BRANCH_NAME"

    git worktree add "$WORKTREE_PATH" "$BRANCH_NAME"
fi

if tmux list-windows -F "#{window_name}" | grep -qx "$WINDOW_NAME"; then
    tmux select-window -t "$WINDOW_NAME"
    exit 0
fi

LLM_COMMAND="${LLM_COMMAND:-claude --dangerously-skip-permissions}"

tmux neww -n "$WINDOW_NAME" -c "$WORKTREE_PATH" "$LLM_COMMAND"
tmux split-window -h -c "$WORKTREE_PATH"
if [ -f "$WORKTREE_PATH/mix.exs" ]; then
    tmux split-window -v -c "$WORKTREE_PATH" "mix setup; exec \$SHELL"
else
    tmux split-window -v -c "$WORKTREE_PATH"
fi
tmux select-pane -t "${WINDOW_NAME}.1"
